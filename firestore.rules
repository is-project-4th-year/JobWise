rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    /// Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /// Check if user is accessing their own data
    function isCurrentUser(userId) {
      return request.auth.uid == userId;
    }

    // ==================== ROLES COLLECTION ====================
    // Read-only for authenticated users, write restricted to admins

    match /roles/{roleId} {
      // Any authenticated user can read roles
      allow read: if isAuthenticated();

      // Only admins can create, update, or delete roles
      // This should be done via Firebase Console or Admin SDK
      allow write: if false;
    }

    // ==================== QUESTIONS COLLECTION ====================
    // Read-only for authenticated users, write restricted to admins

    match /questions/{questionId} {
      // Any authenticated user can read questions
      allow read: if isAuthenticated();

      // Only admins can create, update, or delete questions
      // This should be done via Firebase Console or Admin SDK
      allow write: if false;
    }

    // ==================== USERS COLLECTION ====================
    // Users can only access their own data

    match /users/{userId} {
      // Users can read and write their own user document
      allow read, write: if isOwner(userId);

      // ==================== USER SESSIONS SUBCOLLECTION ====================
      // Users can only access their own interview sessions

      match /sessions/{sessionId} {
        // Users can read and write their own sessions
        allow read, write: if isOwner(userId);

        // Allow creation of new sessions
        allow create: if isOwner(userId);

        // Allow updates to existing sessions
        allow update: if isOwner(userId);

        // Allow deletion of own sessions
        allow delete: if isOwner(userId);
      }

      // ==================== USER PROGRESS SUBCOLLECTION ====================
      // Users can only access their own progress data

      match /progress/{progressId} {
        // Users can read and write their own progress
        allow read, write: if isOwner(userId);

        // Allow creation of new progress documents
        allow create: if isOwner(userId);

        // Allow updates to existing progress
        allow update: if isOwner(userId);
      }
    }

    // ==================== METADATA COLLECTION ====================
    // Read-only for authenticated users (for seeding status)

    match /_metadata/{document=**} {
      // Any authenticated user can read metadata
      allow read: if isAuthenticated();

      // Only system/admins can write metadata
      allow write: if false;
    }

    // ==================== DEFAULT DENY ====================
    // Deny all other requests by default

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
